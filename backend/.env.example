# Copy to .env — loaded via pydantic-settings (prefix EKS_ASSISTANT_)
EKS_ASSISTANT_API_PREFIX=/api/v1
EKS_ASSISTANT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite DB + uploaded kubeconfigs (created automatically)
# EKS_ASSISTANT_DATA_DIR=data

# K8sGPT CLI — Docker image includes binary; override path for local dev if needed
# EKS_ASSISTANT_K8SGPT_BINARY=k8sgpt
# EKS_ASSISTANT_K8SGPT_TIMEOUT_SECONDS=120

# Allow POST /api/v1/remediation/execute (kubectl delete pod / rollout restart). Default false.
# EKS_ASSISTANT_REMEDIATION_ENABLED=false
